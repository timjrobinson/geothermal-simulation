{
  "name": "geosim-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Geothermal Underground Simulator — 3D viewer (React + TS + Three.js)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "esbuild src/lib/*.test.ts --bundle --platform=node --format=esm --packages=external --outdir=.test-out --out-extension:.js=.mjs && node --test .test-out/"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "@react-three/fiber": "^8.17.0",
    "@react-three/drei": "^9.114.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
